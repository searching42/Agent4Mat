# oled-agent environment template
#
# Copy this file to `.env` (or source it in your shell), then fill values
# for the deployment scenario you are using.
#
# Scenario A (recommended for local/CI): LLM command mode + mock/adapter smoke.
# Scenario B (optional): real external adapter runtime (Uni-Mol/MinerU/remote scorer).

# ---------------------------------------------------------------------------
# Common optional mirrors/paths
# ---------------------------------------------------------------------------

HF_ENDPOINT=
UNIMOL_WEIGHT_DIR=
MINERU_HOME=

# ---------------------------------------------------------------------------
# Scenario A: LLM planner configuration
# ---------------------------------------------------------------------------
#
# Command mode (highest priority for llm_v1):
# Example:
# OLED_AGENT_LLM_PLANNER_CMD="python3 scripts/mock_llm_planner.py"

OLED_AGENT_LLM_PLANNER_CMD=
MOCK_LLM_MODE=active

# Built-in openai_compat backend (used only when command mode is empty):
OLED_AGENT_LLM_BACKEND=
OLED_AGENT_LLM_MODEL=
OLED_AGENT_LLM_API_KEY=
OLED_AGENT_LLM_BASE_URL=https://api.openai.com/v1
OLED_AGENT_LLM_CHAT_COMPLETIONS_PATH=/chat/completions
OLED_AGENT_LLM_AUTH_HEADER=Authorization
OLED_AGENT_LLM_AUTH_SCHEME=Bearer
OLED_AGENT_LLM_EXTRA_HEADERS_JSON=
OLED_AGENT_LLM_TIMEOUT_SEC=60
OLED_AGENT_LLM_BACKEND_MAX_RETRIES=0
OLED_AGENT_LLM_BACKEND_BACKOFF_SEC=1
OLED_AGENT_LLM_DISABLE_RESPONSE_FORMAT=0
OLED_AGENT_LLM_DEBUG_ERROR=0

# ---------------------------------------------------------------------------
# Scenario B: external adapter runtime
# ---------------------------------------------------------------------------

# External scorer switch:
OLED_AGENT_USE_EXTERNAL_SCORER=0

# Uni-Mol remote runtime (set all together when enabled):
UNIMOL_REMOTE_HOST=
UNIMOL_REMOTE_PY=
UNIMOL_REMOTE_TMP_BASE=

# Legacy default remote fallback in workspace scorer script (not recommended):
ALLOW_DEFAULT_UNIMOL_REMOTE=0

# External scorer retry policy:
OLED_AGENT_EXTERNAL_SCORER_TIMEOUT_SEC=900
OLED_AGENT_EXTERNAL_SCORER_RETRIES=1
OLED_AGENT_EXTERNAL_SCORER_BACKOFF_SEC=1.5

# Real adapter shells mode controls:
OLED_AGENT_UNIMOL_TRAIN_MODE=preflight
OLED_AGENT_UNIMOL_SCORE_MODE=preflight
OLED_AGENT_MINERU_ADAPTER_MODE=preflight

# Optional adapter timeouts:
OLED_AGENT_UNIMOL_TRAIN_TIMEOUT_SEC=3600
OLED_AGENT_UNIMOL_ADAPTER_TIMEOUT_SEC=900
