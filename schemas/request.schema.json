{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/oled-agent/schemas/request.schema.json",
  "title": "OLED Agent RequestSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "request_text",
    "mode",
    "targets",
    "budget"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["fast_screen", "train_then_design"]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["property", "objective"],
        "properties": {
          "property": {
            "type": "string",
            "enum": ["lambda_em", "plqy", "stability"]
          },
          "objective": {
            "type": "string",
            "enum": ["maximize", "minimize", "target_window"]
          },
          "target_min": { "type": "number" },
          "target_max": { "type": "number" },
          "target_value": { "type": "number" }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mw_max": { "type": "number" },
        "elements_allowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_contain_substructures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_candidates"],
      "properties": {
        "max_candidates": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "timeout_sec": { "type": "integer", "minimum": 1 },
        "max_tool_calls": { "type": "integer", "minimum": 1 }
      }
    },
    "model_preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "predictor_id": { "type": "string" },
        "generator_id": { "type": "string" },
        "routing_policy": {
          "type": "string",
          "enum": ["prefer_primary", "allow_fallback", "cpu_only", "gpu_only"]
        }
      }
    }
  }
}
